[Unit]
Description=HyperOrchestrator API Gateway
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/orch-cloud
EnvironmentFile=-/opt/orch-cloud/.env
ExecStart=/opt/orch-cloud/.venv/bin/uvicorn api_gateway:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
