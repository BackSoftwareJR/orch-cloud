# HyperOrchestrator Platform — environment template
# Copy to /opt/orch-cloud/.env on your VPS

# API authentication (required in production)
ORCHESTRATOR_API_TOKEN=change-me-in-production
REQUIRE_API_TOKEN=true

# SQLite database (default: orchestrator.db in project root)
DATABASE_URL=sqlite:////opt/orch-cloud/orchestrator.db

# Job worker concurrency
MAX_CONCURRENT_JOBS=3

# Orchestrator retry / graceful degradation
MAX_DEBUG_RETRIES=6
PUSH_ON_TEST_FAILURE=true

# CORS origins for dashboard (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://2.24.15.210:3000

# Dashboard — browser uses /api-backend proxy; this is the internal API target for Next.js rewrites
INTERNAL_API_URL=http://127.0.0.1:8000

# When REQUIRE_API_TOKEN=true, set at dashboard build time so Settings and job APIs authenticate:
# NEXT_PUBLIC_ORCHESTRATOR_API_TOKEN=change-me-in-production

# Optional: HMAC secret for outbound job webhooks to backclub.it
# WEBHOOK_SECRET=your-signing-secret

# CORS — include backclub.it in production
# CORS_ORIGINS=https://backclub.it,https://www.backclub.it,http://localhost:3000

# Optional: existing webhook alias
# WEBHOOK_TOKEN=

# GitHub authentication for private repo clone/push (pick one method)
# Option A — Personal Access Token (repo scope):
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#
# Option B — Deploy key (run deploy/setup-github-deploy-key.sh, add .pub to GitHub):
# GITHUB_SSH_KEY_PATH=/root/.ssh/orchestrator_deploy_key

# Cursor agent — REQUIRED (pick one location)
# Option A: Dashboard → Settings (recommended; hot-reloads without VPS reboot)
# Option B: run ./deploy/setup-cursor-api-key.sh
# Option C: uncomment here AND in /opt/agent-orchestrator/config/agent.env
# CURSOR_API_KEY=key_xxxxxxxxxxxxxxxx
